{
  "name": "@luciaocr/angular",
  "version": "1.0.0",
  "private": false,
  "type": "module",
  "description": "Angular-friendly luciaocr package built on top of @luciaocr/web.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/FM7077/luciaocr.git",
    "directory": "packages/sdk-angular"
  },
  "homepage": "https://github.com/FM7077/luciaocr/tree/main/packages/sdk-angular",
  "bugs": {
    "url": "https://github.com/FM7077/luciaocr/issues"
  },
  "main": "./src/index.js",
  "module": "./src/index.js",
  "types": "./src/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "import": "./src/index.js",
      "default": "./src/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "src",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "echo sdk-angular build placeholder",
    "clean": "echo sdk-angular clean placeholder",
    "lint": "echo sdk-angular lint placeholder",
    "test": "echo sdk-angular test placeholder",
    "typecheck": "echo sdk-angular typecheck placeholder"
  },
  "dependencies": {
    "@luciaocr/web": "file:../sdk-web"
  },
  "peerDependencies": {
    "@angular/core": "^20.0.0",
    "@angular/common": "^20.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
